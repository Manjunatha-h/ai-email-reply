{
  "name": "AI Mail Writer",
  "description": "AI Powered Assistant for writing emails",
  "version": "1.0",
  "manifest_version": 3,
  
  "action": {
    "default_title": "AI Mail Writer",
    "default_icon": "image.png"
  },


  "permissions":[
    "activeTab",
    "storage"
  ],


  "host_permissions": [
    "http://localhost:8080/*",
    "*://mail.google.com/*"
  ],


  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["*://mail.google.com/*"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [ "icons/*" ],
      "matches": ["*://mail.google.com/*"]
    }
  ]
}